<?xml version="1.0"?>

<component name="audit-pageprovider">

    <extension target="org.nuxeo.ecm.platform.query.api.PageProviderService"
               point="providers">

        <genericPageProvider name="GetAllEntriesByEvent"
                             class="org.nuxeo.audit.provider.AuditPageProvider">
            <pattern>
                SELECT * FROM LogEntry WHERE eventId = ? AND docUUID = ?
            </pattern>
            <sort column="id" ascending="true"/>
            <pageSize>2</pageSize>
        </genericPageProvider>

    </extension>
</component>
